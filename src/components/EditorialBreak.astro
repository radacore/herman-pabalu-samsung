---
// EditorialBreak — DESIGN.md component: centered illustration + headline + body
// for section headers. Uses hand-drawn inline SVG (eye, target, scribble)
// in sky-mist, blossom-pink, and yellow per spec.

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  illustration?: 'eye' | 'target' | 'scribble' | 'arrows';
  align?: 'center' | 'left';
}

const { eyebrow, title, subtitle, illustration = 'target', align = 'center' } = Astro.props;

// Hand-rolled decorative SVGs (per Section 4.8, acceptable when brief explicitly calls — DESIGN.md does)
const illustrations = {
  target: `<svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="32" cy="32" r="26" stroke="#add3e5" fill="#add3e5" fill-opacity="0.2"/>
    <circle cx="32" cy="32" r="18" stroke="#add3e5"/>
    <circle cx="32" cy="32" r="10" stroke="#e3c7de"/>
    <circle cx="32" cy="32" r="3" fill="#ffba09" stroke="#ffba09"/>
  </svg>`,
  eye: `<svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M8 32C16 18 28 14 32 14C36 14 48 18 56 32C48 46 36 50 32 50C28 50 16 46 8 32Z" stroke="#1a1a1a" fill="#ffffff"/>
    <circle cx="32" cy="32" r="8" fill="#1009f6" stroke="#1009f6"/>
    <circle cx="32" cy="32" r="3" fill="#ffffff" stroke="#ffffff"/>
  </svg>`,
  scribble: `<svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M8 40C14 28 18 44 24 32C30 20 34 44 40 32C46 20 50 44 56 36" stroke="#1009f6"/>
    <circle cx="14" cy="22" r="2.5" fill="#ffba09" stroke="#ffba09"/>
    <circle cx="48" cy="44" r="2" fill="#add3e5" stroke="#add3e5"/>
  </svg>`,
  arrows: `<svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M12 22L52 22M44 14L52 22L44 30" stroke="#1a1a1a"/>
    <path d="M52 42L12 42M20 34L12 42L20 50" stroke="#1009f6"/>
    <circle cx="32" cy="32" r="3" fill="#ffba09" stroke="#ffba09"/>
  </svg>`,
};
---

<div class={align === 'center' ? 'text-center max-w-2xl mx-auto' : 'max-w-2xl'}>
  <div class={align === 'center' ? 'flex justify-center mb-5' : 'mb-5'}>
    <div class="w-14 h-14 md:w-16 md:h-16" set:html={illustrations[illustration]} />
  </div>
  {eyebrow && <p class="eyebrow mb-3">{eyebrow}</p>}
  <h2 class="section-title mb-4">{title}</h2>
  {subtitle && <p class="section-subtitle mx-auto">{subtitle}</p>}
</div>
