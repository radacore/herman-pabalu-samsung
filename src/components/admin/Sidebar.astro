---

<aside
  data-sidebar
  class="fixed left-0 top-0 z-40 h-screen w-60 bg-samsung-ink text-white
         -translate-x-full lg:translate-x-0 transition-transform duration-200 ease-out
         flex flex-col"
>
  <!-- Brand -->
  <a
    href="/admin"
    class="flex items-center gap-2.5 px-5 h-14 border-b border-white/10 hover:bg-white/5 transition-colors"
  >
    <div class="w-8 h-8 rounded-lg bg-samsung-blue flex items-center justify-center">
      <span class="text-white font-display font-bold text-sm leading-none">H</span>
    </div>
    <div class="leading-tight min-w-0">
      <p class="font-display font-bold text-sm tracking-tight truncate">Herman Samsung</p>
      <p class="text-[10px] uppercase tracking-[0.15em] text-white/40 font-medium">Admin</p>
    </div>
  </a>

  <!-- Nav -->
  <nav class="flex-1 overflow-y-auto py-4 px-3">
    {sections.map((section) => (
      <div class="mb-5 last:mb-0">
        <p class="px-3 mb-1.5 text-[10px] uppercase tracking-[0.15em] text-white/30 font-semibold">
          {section.label}
        </p>
        <ul class="space-y-0.5">
          {section.items.map((item) => {
            const isActive = activeMenu === item.id;
            return (
              <li>
                <a
                  href={item.href}
                  data-sidebar-link
                  aria-current={isActive ? 'page' : undefined}
                  class={`group relative flex items-center gap-2.5 pl-3 pr-3 py-2 rounded-[10px] text-sm transition-all duration-150 ${
                    isActive
                      ? 'bg-samsung-blue text-white font-semibold shadow-md shadow-samsung-blue/25'
                      : 'text-white/60 hover:text-white hover:bg-white/5 font-medium'
                  }`}
                >
                  <svg class={`w-[18px] h-[18px] flex-shrink-0 transition-transform duration-150 ${isActive ? 'scale-110' : ''}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={isActive ? '2' : '1.75'} stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d={item.icon} />
                  </svg>
                  <span class="truncate">{item.label}</span>
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </nav>

  <!-- Footer (account actions) -->
  <div class="border-t border-white/10 p-3 space-y-0.5">
    <a
      href="/"
      target="_blank"
      rel="noopener"
      class="flex items-center gap-2.5 px-3 py-2 rounded-[10px] text-sm font-medium text-white/60 hover:bg-white/5 hover:text-white transition-colors duration-150"
    >
      <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3" />
      </svg>
      <span>Lihat Website</span>
    </a>
    <button
      type="button"
      data-sidebar-logout
      class="w-full flex items-center gap-2.5 px-3 py-2 rounded-[10px] text-sm font-medium text-white/60 hover:bg-red-500/10 hover:text-red-400 transition-colors duration-150"
    >
      <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9" />
      </svg>
      <span>Logout</span>
    </button>
  </div>
</aside>

<!-- Backdrop (mobile only) -->
<div
  data-sidebar-backdrop
  class="fixed inset-0 z-30 bg-samsung-ink/50 backdrop-blur-sm opacity-0 pointer-events-none lg:hidden transition-opacity duration-200"
></div>

<script>
  // Sidebar drawer toggle for mobile
  const sidebar = document.querySelector<HTMLElement>('[data-sidebar]');
  const backdrop = document.querySelector<HTMLElement>('[data-sidebar-backdrop]');
  const toggles = document.querySelectorAll<HTMLElement>('[data-sidebar-toggle]');
  const links = document.querySelectorAll<HTMLElement>('[data-sidebar-link]');

  function open() {
    sidebar?.classList.remove('-translate-x-full');
    backdrop?.classList.remove('opacity-0', 'pointer-events-none');
    backdrop?.classList.add('opacity-100');
    document.body.style.overflow = 'hidden';
  }
  function close() {
    sidebar?.classList.add('-translate-x-full');
    backdrop?.classList.add('opacity-0', 'pointer-events-none');
    backdrop?.classList.remove('opacity-100');
    document.body.style.overflow = '';
  }

  toggles.forEach((btn) => btn.addEventListener('click', open));
  backdrop?.addEventListener('click', close);
  // Close drawer on link click (mobile only)
  links.forEach((l) =>
    l.addEventListener('click', () => {
      if (window.innerWidth < 1024) close();
    })
  );
</script>
