---
interface Props {
  label: string;
  value: number | string;
  icon: string;
  accent?: 'blue' | 'green' | 'red' | 'purple';
  ratio?: { current: number; total: number };
  href?: string;
}

const { label, value, icon, accent = 'blue', ratio, href } = Astro.props;

const accentStyles: Record<string, { bg: string; text: string }> = {
  blue: { bg: 'bg-samsung-blue/10', text: 'text-samsung-blue' },
  green: { bg: 'bg-emerald-50', text: 'text-emerald-600' },
  red: { bg: 'bg-red-50', text: 'text-red-600' },
  purple: { bg: 'bg-purple-50', text: 'text-purple-600' },
};
const a = accentStyles[accent] || accentStyles.blue;

const ratioPct = ratio && ratio.total > 0 ? Math.round((ratio.current / ratio.total) * 100) : null;

const Wrapper = href ? 'a' : 'div';
---

<Wrapper
  {...(href ? { href } : {})}
  class="admin-card p-5 block transition-shadow hover:shadow-cardHover"
>
  <div class="flex items-start justify-between gap-3 mb-3">
    <p class="text-xs font-medium text-samsung-ink/50 uppercase tracking-[0.08em]">
      {label}
    </p>
    <div class={`w-8 h-8 rounded-lg ${a.bg} flex items-center justify-center flex-shrink-0`}>
      <svg class={`w-4 h-4 ${a.text}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d={icon} />
      </svg>
    </div>
  </div>

  <p class="font-display text-3xl font-bold text-samsung-ink tracking-tight leading-none mb-2">
    {value}
  </p>

  {ratioPct !== null && (
    <div class="flex items-center gap-2">
      <div class="h-1 flex-1 bg-samsung-ink/5 rounded-full overflow-hidden">
        <div
          class={`h-full ${a.text.replace('text-', 'bg-')} transition-all duration-500`}
          style={`width: ${ratioPct}%`}
        ></div>
      </div>
      <span class="text-[10px] text-samsung-ink/50 font-medium tabular-nums">{ratioPct}%</span>
    </div>
  )}
</Wrapper>
