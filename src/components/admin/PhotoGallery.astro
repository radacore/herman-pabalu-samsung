---
import type { ProdukFoto } from '../../lib/types';

interface Props {
  produkId: string;
  photos: ProdukFoto[];
}

const { produkId, photos } = Astro.props;
---

<section
  class="admin-card p-5"
  data-photo-gallery
  data-produk-id={produkId}
>
  <div class="flex items-center justify-between mb-4">
    <div>
      <h2 class="font-display font-semibold text-samsung-ink">Galeri Foto</h2>
      <p class="text-xs text-samsung-ink/50 mt-0.5">
        {photos.length} foto · foto utama akan tampil pertama di website
      </p>
    </div>
  </div>

  {photos.length === 0 ? (
    <div class="border-2 border-dashed border-samsung-ink/10 rounded-xl p-8 text-center">
      <p class="text-sm text-samsung-ink/50">
        Belum ada foto. Upload foto dari halaman
        <a href="/admin/upload" class="text-samsung-blue hover:underline ml-1">Upload Foto</a>.
      </p>
    </div>
  ) : (
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
      {photos.map((photo) => (
        <div
          class="relative group rounded-xl overflow-hidden border border-samsung-ink/10 bg-samsung-mist aspect-square"
          data-photo-id={photo.id}
          data-photo-url={photo.url}
        >
          <img
            src={photo.url}
            alt=""
            class="w-full h-full object-cover"
            loading="lazy"
          />

          {photo.is_primary && (
            <span class="absolute top-2 left-2 px-2 py-0.5 rounded-full text-caption font-bold bg-yellow text-ink">
              Utama
            </span>
          )}

          <div class="absolute inset-0 bg-ink/0 group-hover:bg-ink/60 transition-colors flex items-center justify-center gap-2 opacity-0 group-hover:opacity-100">
            {!photo.is_primary && (
              <button
                type="button"
                data-set-primary
                class="inline-flex items-center gap-1 px-2.5 py-1.5 rounded-lg bg-white text-ink text-xs font-semibold hover:bg-yellow transition-colors"
                aria-label="Jadikan foto utama"
              >
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 2l2.39 7.36H22l-6.18 4.49L18.18 21 12 16.27 5.82 21l2.36-7.15L2 9.36h7.61L12 2z"/>
                </svg>
                Utama
              </button>
            )}
            <button
              type="button"
              data-delete-photo
              class="inline-flex items-center gap-1 px-2.5 py-1.5 rounded-lg bg-white text-red-600 text-xs font-semibold hover:bg-red-50 transition-colors"
              aria-label="Hapus foto"
            >
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M3 6h18M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2M10 11v6M14 11v6"/>
              </svg>
              Hapus
            </button>
          </div>
        </div>
      ))}
    </div>
  )}
</section>

<script>
  import { toast } from '../../lib/toast';
  import '../../lib/confirm';

  const gallery = document.querySelector<HTMLElement>('[data-photo-gallery]');
  if (gallery) {
    gallery.addEventListener('click', async (e) => {
      const target = e.target as HTMLElement;
      const card = target.closest<HTMLElement>('[data-photo-id]');
      if (!card) return;
      const id = card.dataset.photoId;
      const url = card.dataset.photoUrl;
      if (!id || !url) return;

      if (target.closest('[data-set-primary]')) {
        try {
          const res = await fetch(`/api/upload?id=${encodeURIComponent(id)}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ is_primary: true }),
          });
          const json = await res.json().catch(() => null);
          if (!res.ok) {
            toast.error((json && json.error) || 'Gagal set foto utama');
            return;
          }
          toast.success('Foto utama diperbarui.');
          setTimeout(() => window.location.reload(), 600);
        } catch (err) {
          toast.error((err as Error).message || 'Gagal set foto utama');
        }
        return;
      }

      if (target.closest('[data-delete-photo]')) {
        try {
          const ok = await (window as any).confirmDialog({
            title: 'Hapus foto ini?',
            message: 'Foto akan dihapus permanen dari produk.',
            confirmText: 'Hapus',
            variant: 'danger',
            onConfirm: async () => {
              const res = await fetch(`/api/upload?url=${encodeURIComponent(url!)}`, {
                method: 'DELETE',
              });
              const json = await res.json().catch(() => null);
              if (!res.ok) {
                const msg = (json && json.error) || 'Gagal menghapus foto';
                toast.error(msg);
                throw new Error(msg);
              }
            },
          });
          if (ok) {
            toast.success('Foto dihapus.');
            card.style.transition = 'opacity 200ms, transform 200ms';
            card.style.opacity = '0';
            card.style.transform = 'scale(0.95)';
            setTimeout(() => card.remove(), 220);
          }
        } catch (_) {
          // Error already toasted
        }
      }
    });
  }
</script>
