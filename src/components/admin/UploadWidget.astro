---
---

<div class="bg-white p-6 rounded-lg shadow">
  <h3 class="text-lg font-semibold mb-4">Upload Foto Produk</h3>

  <!-- File Input -->
  <div class="mb-4">
    <label class="block text-sm font-medium text-gray-700 mb-2">
      Pilih Produk
    </label>
    <select
      id="produk-select"
      class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-samsung-blue focus:border-transparent"
    >
      <option value="">-- Pilih Produk --</option>
    </select>
  </div>

  <!-- Drop Zone -->
  <div
    id="drop-zone"
    class="border-2 border-dashed border-gray-300 rounded-lg p-8 text-center hover:border-samsung-blue transition-colors cursor-pointer"
  >
    <svg class="mx-auto h-12 w-12 text-gray-400" stroke="currentColor" fill="none" viewBox="0 0 48 48">
      <path
        d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>
    <p class="mt-2 text-sm text-gray-600">
      <span class="font-semibold text-samsung-blue">Klik untuk upload</span> atau drag and drop
    </p>
    <p class="text-xs text-gray-500 mt-1">PNG, JPG, WebP hingga 5MB</p>
    <input
      type="file"
      id="file-input"
      multiple
      accept="image/*"
      class="hidden"
    />
  </div>

  <!-- Preview -->
  <div id="preview-container" class="mt-6 grid grid-cols-2 md:grid-cols-4 gap-4"></div>

  <!-- Upload Button -->
  <button
    id="upload-btn"
    disabled
    class="mt-6 w-full px-6 py-3 bg-samsung-blue text-white rounded-lg hover:bg-samsung-darkblue transition-colors font-medium disabled:bg-gray-300 disabled:cursor-not-allowed"
  >
    Upload Foto
  </button>

  <!-- Progress -->
  <div id="progress-container" class="mt-4 hidden">
    <div class="bg-gray-200 rounded-full h-2 overflow-hidden">
      <div id="progress-bar" class="bg-samsung-blue h-full transition-all duration-300" style="width: 0%"></div>
    </div>
    <p id="progress-text" class="text-sm text-gray-600 mt-2 text-center"></p>
  </div>
</div>

<script>
  import { supabaseBrowser } from '../../lib/supabase-browser';
  import { toast } from '../../lib/toast';
  import '../../lib/confirm';

  const dropZone = document.getElementById('drop-zone');
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const previewContainer = document.getElementById('preview-container');
  const uploadBtn = document.getElementById('upload-btn') as HTMLButtonElement;
  const produkSelect = document.getElementById('produk-select') as HTMLSelectElement;
  const progressContainer = document.getElementById('progress-container');
  const progressBar = document.getElementById('progress-bar');
  const progressText = document.getElementById('progress-text');

  let selectedFiles: File[] = [];

  // Load produk list
  async function loadProduk() {
    try {
      const res = await fetch('/api/produk?pageSize=100');
      const { data } = await res.json();
      (data || []).forEach((p: any) => {
        const option = document.createElement('option');
        option.value = p.id;
        option.textContent = p.nama;
        produkSelect.appendChild(option);
      });
    } catch (err) {
      console.error('Failed to load produk:', err);
    }
  }
  loadProduk();

  // Click to select files
  dropZone?.addEventListener('click', () => fileInput?.click());

  // Drag and drop
  dropZone?.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('border-samsung-blue', 'bg-samsung-blue/5');
  });

  dropZone?.addEventListener('dragleave', () => {
    dropZone.classList.remove('border-samsung-blue', 'bg-samsung-blue/5');
  });

  dropZone?.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('border-samsung-blue', 'bg-samsung-blue/5');
    handleFiles(Array.from(e.dataTransfer?.files || []));
  });

  fileInput?.addEventListener('change', (e) => {
    handleFiles(Array.from((e.target as HTMLInputElement).files || []));
  });

  function handleFiles(files: File[]) {
    selectedFiles = files;
    previewContainer!.innerHTML = '';

    files.forEach((file) => {
      const reader = new FileReader();
      reader.onload = (e) => {
        const div = document.createElement('div');
        div.className = 'relative';
        div.innerHTML = `
          <img src="${e.target?.result}" class="w-full h-32 object-cover rounded-lg" />
          <p class="text-xs text-gray-600 mt-1 truncate">${file.name}</p>
        `;
        previewContainer!.appendChild(div);
      };
      reader.readAsDataURL(file);
    });

    uploadBtn.disabled = files.length === 0 || !produkSelect.value;
  }

  produkSelect?.addEventListener('change', () => {
    uploadBtn.disabled = selectedFiles.length === 0 || !produkSelect.value;
  });

  // Upload
  uploadBtn?.addEventListener('click', async () => {
    if (!produkSelect.value || selectedFiles.length === 0) return;

    uploadBtn.disabled = true;
    progressContainer?.classList.remove('hidden');

    let uploaded = 0;
    const total = selectedFiles.length;

    for (const file of selectedFiles) {
      try {
        const formData = new FormData();
        formData.append('produk_id', produkSelect.value);
        formData.append('file', file);

        const res = await fetch('/api/upload', {
          method: 'POST',
          body: formData,
        });

        const json = await res.json().catch(() => null);
        if (!res.ok) {
          const msg = (json && json.error) || `HTTP ${res.status}`;
          progressText!.textContent = `Gagal upload ${file.name}: ${msg}`;
          progressText!.classList.add('text-red-600');
          continue;
        }

        uploaded++;
        const percent = Math.round((uploaded / total) * 100);
        progressBar!.style.width = `${percent}%`;
        progressText!.textContent = `${uploaded}/${total} foto diupload`;
      } catch (err) {
        progressText!.textContent = `Gagal upload ${file.name}: ${(err as Error).message}`;
        progressText!.classList.add('text-red-600');
      }
    }

    if (uploaded > 0) {
      sessionStorage.setItem('toast', JSON.stringify({
        type: 'success',
        message: `${uploaded}/${total} foto berhasil diupload.`,
      }));
    }
    setTimeout(() => {
      window.location.reload();
    }, 800);
  });
</script>
