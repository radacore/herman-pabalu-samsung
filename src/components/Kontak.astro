---
import EditorialBreak from './EditorialBreak.astro';

interface Props {
  profil: {
    alamat: string;
    whatsapp: string;
    telepon: string;
    email: string;
    jam_operasional: string;
  };
}

const { profil } = Astro.props;
const waClean = String(profil.whatsapp || '').replace(/[^0-9]/g, '');
const telClean = String(profil.telepon || '').replace(/[^0-9+]/g, '');
const waHref = waClean ? `https://wa.me/${waClean}?text=Halo%20Pak%20Herman` : '#';
const mapsQuery = encodeURIComponent(profil.alamat || 'Jakarta, Indonesia');
const mapsHref = `https://www.google.com/maps/search/?api=1&query=${mapsQuery}`;

const checkList = [
  'Respon WhatsApp di bawah 5 menit',
  'Konsultasi gratis sebelum beli',
  'Garansi resmi Samsung Indonesia',
];

const checkIcon = 'M20 6L9 17l-5-5';

const items = [
  {
    iconBg: 'bg-whatsapp/10',
    iconColor: 'text-whatsapp',
    iconPath: 'M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z',
    title: 'WhatsApp',
    value: profil.whatsapp || '—',
    action: waClean ? { label: 'Chat langsung', href: waHref, external: true } : null,
  },
  {
    iconBg: 'bg-violet/10',
    iconColor: 'text-violet',
    iconPath: 'M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z',
    title: 'Telepon',
    value: profil.telepon || '—',
    action: telClean ? { label: 'Telepon sekarang', href: `tel:${telClean}`, external: false } : null,
  },
  {
    iconBg: 'bg-yellow/30',
    iconColor: 'text-ink',
    iconPath: 'M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2zM22 6l-10 7L2 6',
    title: 'Email',
    value: profil.email || '—',
    action: profil.email ? { label: 'Kirim email', href: `mailto:${profil.email}`, external: false } : null,
  },
  {
    iconBg: 'bg-blossom/50',
    iconColor: 'text-ink',
    iconPath: 'M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10zM12 6v6l4 2',
    title: 'Jam Operasional',
    value: profil.jam_operasional || 'Senin - Sabtu, 09.00 - 17.00 WIB',
    action: null,
  },
  {
    iconBg: 'bg-skymist/50',
    iconColor: 'text-ink',
    iconPath: 'M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0zM12 13a3 3 0 1 0 0-6 3 3 0 0 0 0 6z',
    title: 'Alamat',
    value: profil.alamat || '—',
    action: { label: 'Buka di Google Maps', href: mapsHref, external: true },
  },
];
---

<!-- DESIGN.md Demo Request Form: 2-col layout — copy+checklist left, contact cards right -->
<section id="kontak" class="py-20 md:py-28 bg-cream">
  <div class="container-content">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
      <!-- Left: copy + checkmark list -->
      <div class="lg:col-span-5">
        <div class="lg:sticky lg:top-24">
          <EditorialBreak
            eyebrow="Kontak"
            title="Mari ngobrol langsung."
            subtitle="Konsultasi gratis, tanpa tekanan. Balasan cepat, hari yang sama."
            illustration="arrows"
            align="left"
          />

          <ul class="space-y-3 mt-8 mb-8">
            {checkList.map((item) => (
              <li class="check-list-item">
                <svg class="check-violet" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={checkIcon} />
                </svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>

          <!-- Yellow CTA — WhatsApp -->
          <a href={waHref} target="_blank" rel="noopener" class="btn-yellow">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z" />
            </svg>
            Chat WhatsApp
          </a>
        </div>
      </div>

      <!-- Right: 5 contact cards (2-col grid) — DESIGN.md white card pattern -->
      <div class="lg:col-span-7">
        <div class="grid sm:grid-cols-2 gap-4 reveal-stagger">
          {items.map((item) => (
            <div class="card-white p-6">
              <div class={`w-11 h-11 rounded-xl ${item.iconBg} flex items-center justify-center mb-4`}>
                <svg class={`w-5 h-5 ${item.iconColor}`} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d={item.iconPath} />
                </svg>
              </div>
              <h3 class="font-display font-semibold text-ink text-sm tracking-tight mb-1">
                {item.title}
              </h3>
              <p class="text-charcoal/80 text-sm leading-relaxed mb-3 break-words">
                {item.value}
              </p>
              {item.action && (
                <a
                  href={item.action.href}
                  target={item.action.external ? '_blank' : undefined}
                  rel={item.action.external ? 'noopener' : undefined}
                  class="inline-flex items-center gap-1 text-sm font-medium text-violet hover:text-violet-deep transition-colors"
                >
                  {item.action.label}
                  <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M5 12h14M13 5l7 7-7 7" />
                  </svg>
                </a>
              )}
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
