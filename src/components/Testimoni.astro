---
import EditorialBreak from './EditorialBreak.astro';

interface Props {
  testimoniList?: { nama: string; rating: number; komentar: string; tanggal?: string }[];
}

const { testimoniList = [] } = Astro.props;
const list = testimoniList;

function formatTanggal(iso?: string): string {
  if (!iso) return '';
  const d = new Date(iso);
  if (isNaN(d.getTime())) return '';
  return d.toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' });
}
---

<section id="testimoni" class="py-20 md:py-28 bg-cream">
  <div class="container-content">
    <div class="mb-12 reveal">
      <EditorialBreak
        eyebrow="Testimoni"
        title="Apa kata mereka yang sudah beli."
        subtitle="Pengalaman nyata dari pelanggan."
        illustration="scribble"
      />
    </div>

    {list.length === 0 ? (
      <div class="text-center py-12 text-charcoal/70">
        <p>Belum ada testimoni.</p>
      </div>
    ) : (
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4 reveal-stagger">
        {list.map((item) => (
          <article class="card-white p-6 hover:border-silver transition-colors duration-200">
            <!-- Stars: yellow (sparingly) per spec -->
            <div class="flex gap-0.5 mb-3" aria-label={`Rating ${item.rating} dari 5`}>
              {Array.from({ length: 5 }).map((_, i) => (
                <svg class={`w-4 h-4 ${i < item.rating ? 'text-yellow' : 'text-stone'}`} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              ))}
            </div>

            <p class="text-charcoal text-body leading-[1.6] mb-5">
              &ldquo;{item.komentar}&rdquo;
            </p>

            <div class="flex items-center gap-3 pt-4 border-t border-stone">
              <div class="w-9 h-9 bg-violet rounded-full flex items-center justify-center flex-shrink-0">
                <span class="text-white font-display font-semibold text-caption">
                  {item.nama.charAt(0)}
                </span>
              </div>
              <div class="leading-tight min-w-0">
                <p class="font-display font-semibold text-ink text-sm truncate">{item.nama}</p>
                <p class="text-caption text-charcoal/70">
                  {formatTanggal(item.tanggal) || 'Pelanggan'}
                </p>
              </div>
            </div>
          </article>
        ))}
      </div>
    )}
  </div>
</section>
