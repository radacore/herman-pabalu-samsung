---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import ProdukForm from '../../../components/admin/ProdukForm.astro';
import PhotoGallery from '../../../components/admin/PhotoGallery.astro';
import { supabase } from '../../../lib/supabase';

const id = Astro.url.searchParams.get('id');

if (!id) {
  return Astro.redirect('/admin/produk');
}

const { data: produkData, error } = await supabase
  .from('produk')
  .select(`
    *,
    produk_foto:produk_images(*)
  `)
  .eq('id', id)
  .single();

if (error || !produkData) {
  console.error('Error fetching produk:', error);
  return new Response('Produk tidak ditemukan', { status: 404 });
}

const produk = produkData;
const photos = (produk.produk_foto || []).sort((a: any, b: any) => {
  if (a.is_primary && !b.is_primary) return -1;
  if (!a.is_primary && b.is_primary) return 1;
  return 0;
});
---

<AdminLayout title="Edit Produk">
  <div class="max-w-4xl space-y-6">
    <div>
      <h2 class="font-display text-2xl font-bold text-samsung-ink tracking-tight">Edit Produk</h2>
      <p class="text-sm text-samsung-ink/50 mt-1">{produk.nama}</p>
    </div>

    <ProdukForm produk={produk} />
    <PhotoGallery produkId={produk.id} photos={photos} />
  </div>
</AdminLayout>
