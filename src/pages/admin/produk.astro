---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabase } from '../../lib/supabase';

const { data: produkData, error } = await supabase
  .from('produk')
  .select(`
    *,
    produk_foto:produk_images(*)
  `)
  .order('created_at', { ascending: false });

if (error) {
  console.error('Error fetching produk:', error);
}

const produkList = produkData || [];

function formatRupiah(n: number) {
  return new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(n);
}
---

<AdminLayout title="Produk" activeMenu="produk">
  <div class="flex items-end justify-between gap-4 mb-6">
    <div>
      <h2 class="font-display text-2xl font-bold text-samsung-ink tracking-tight">Daftar Produk</h2>
      <p class="text-sm text-samsung-ink/50 mt-1">{produkList.length} produk total</p>
    </div>
    <a href="/admin/produk/tambah" class="btn-primary text-sm">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 5v14M5 12h14" />
      </svg>
      Tambah Produk
    </a>
  </div>

  {produkList.length === 0 ? (
    <div class="admin-card p-12 text-center">
      <p class="text-samsung-ink/50 mb-4">Belum ada produk.</p>
      <a href="/admin/produk/tambah" class="btn-primary text-sm inline-flex">Tambah Produk Pertama</a>
    </div>
  ) : (
    <div class="admin-card overflow-hidden">
      <div class="overflow-x-auto">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Produk</th>
              <th>Kategori</th>
              <th>Harga</th>
              <th>Stok</th>
              <th>Featured</th>
              <th class="text-right">Aksi</th>
            </tr>
          </thead>
          <tbody>
            {produkList.map((produk) => (
              <tr>
                <td>
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-lg bg-samsung-mist overflow-hidden flex-shrink-0">
                      {produk.produk_foto?.[0]?.url ? (
                        <img src={produk.produk_foto[0].url} alt="" class="w-full h-full object-cover" />
                      ) : (
                        <div class="w-full h-full flex items-center justify-center">
                          <svg class="w-5 h-5 text-samsung-ink/20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                            <rect x="5" y="2" width="14" height="20" rx="2" ry="2" />
                          </svg>
                        </div>
                      )}
                    </div>
                    <div class="min-w-0">
                      <p class="font-medium text-samsung-ink truncate">{produk.nama}</p>
                      <p class="text-xs text-samsung-ink/50 truncate">
                        {(produk.spesifikasi as any)?.ram} &middot; {(produk.spesifikasi as any)?.storage}
                      </p>
                    </div>
                  </div>
                </td>
                <td>
                  <span class="badge-neutral capitalize">{produk.kategori}</span>
                </td>
                <td class="tabular-nums font-medium text-samsung-ink">
                  {formatRupiah(produk.harga)}
                </td>
                <td>
                  {produk.stok
                    ? <span class="badge-success">Tersedia</span>
                    : <span class="badge-danger">Habis</span>
                  }
                </td>
                <td>
                  {produk.is_featured
                    ? <span class="badge-warning">Featured</span>
                    : <span class="text-samsung-ink/30">&mdash;</span>
                  }
                </td>
                <td>
                  <div class="flex items-center justify-end gap-1">
                    <a
                      href={`/admin/produk/edit?id=${produk.id}`}
                      aria-label="Edit produk"
                      class="inline-flex items-center justify-center w-8 h-8 rounded-lg text-samsung-ink/60 hover:bg-samsung-blue/10 hover:text-samsung-blue transition-colors"
                    >
                      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" />
                        <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" />
                      </svg>
                    </a>
                    <button
                      data-id={produk.id}
                      data-name={produk.nama}
                      class="delete-btn inline-flex items-center justify-center w-8 h-8 rounded-lg text-samsung-ink/60 hover:bg-red-50 hover:text-red-600 transition-colors"
                      aria-label="Hapus produk"
                    >
                      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M3 6h18M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2M10 11v6M14 11v6" />
                      </svg>
                    </button>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  )}
</AdminLayout>

<script>
  import { toast } from '../../lib/toast';
  import '../../lib/confirm';

  document.querySelectorAll<HTMLButtonElement>('.delete-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const id = btn.dataset.id;
      const name = btn.dataset.name || 'produk ini';
      if (!id) return;

      try {
        const ok = await (window as any).confirmDialog({
          title: `Hapus "${name}"?`,
          message: 'Tindakan ini tidak bisa dibatalkan. Produk akan dihapus permanen dari database.',
          confirmText: 'Hapus',
          variant: 'danger',
          onConfirm: async () => {
            const res = await fetch(`/api/produk?id=${encodeURIComponent(id)}`, { method: 'DELETE' });
            const json = await res.json().catch(() => null);
            if (!res.ok) {
              const msg = (json && json.error) || `Gagal menghapus (HTTP ${res.status})`;
              toast.error(msg);
              throw new Error(msg);
            }
          },
        });
        if (ok) {
          toast.success(`"${name}" berhasil dihapus.`);
          setTimeout(() => window.location.reload(), 800);
        }
      } catch (err) {
        // Error already toasted
      }
    });
  });
</script>
