---
import AdminLayout from '../../layouts/AdminLayout.astro';
import Pagination from '../../components/admin/Pagination.astro';
import { supabase } from '../../lib/supabase';

const page = Math.max(1, Number(Astro.url.searchParams.get('page') || 1));
const pageSize = 20;
const q = (Astro.url.searchParams.get('q') || '').trim();
const from = (page - 1) * pageSize;
const to = from + pageSize - 1;

let query = supabase
  .from('produk')
  .select(`
    *,
    produk_foto:produk_images(*)
  `, { count: 'exact' })
  .order('sort_order', { ascending: true })
  .order('created_at', { ascending: false });

if (q) {
  query = query.ilike('nama', `%${q}%`);
}

const { data: produkData, error, count } = await query.range(from, to);

if (error) {
  console.error('Error fetching produk:', error);
}

const produkList = (produkData || []).map((p: any) => ({
  ...p,
  produk_foto: [...(p.produk_foto || [])].sort((a: any, b: any) => {
    if (a.is_primary && !b.is_primary) return -1;
    if (!a.is_primary && b.is_primary) return 1;
    return 0;
  }),
}));
const total = count || 0;
const totalPages = Math.max(1, Math.ceil(total / pageSize));

function formatRupiah(n: number) {
  return new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(n);
}
---

<AdminLayout title="Produk" activeMenu="produk">
  <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-6">
    <div>
      <h2 class="font-display text-2xl font-bold text-samsung-ink tracking-tight">Daftar Produk</h2>
      <p class="text-sm text-samsung-ink/50 mt-1">
        {q ? `${total} hasil untuk "${q}"` : `${total} produk total`}
      </p>
    </div>
    <div class="flex items-center gap-2">
      <form method="get" action="/admin/produk" class="relative">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-samsung-ink/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
        </svg>
        <input
          type="search"
          name="q"
          value={q}
          placeholder="Cari produk..."
          class="input-admin-sm pl-9 w-48 sm:w-56"
          autocomplete="off"
        />
      </form>
      <a href="/admin/produk/tambah" class="btn-primary text-sm flex-shrink-0">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 5v14M5 12h14" />
        </svg>
        Tambah
      </a>
    </div>
  </div>

  {produkList.length === 0 ? (
    <div class="admin-card p-12 text-center">
      {q ? (
        <>
          <p class="text-samsung-ink/50 mb-4">Tidak ada produk yang cocok dengan "{q}".</p>
          <a href="/admin/produk" class="btn-primary text-sm inline-flex">Lihat Semua</a>
        </>
      ) : (
        <>
          <p class="text-samsung-ink/50 mb-4">Belum ada produk.</p>
          <a href="/admin/produk/tambah" class="btn-primary text-sm inline-flex">Tambah Produk Pertama</a>
        </>
      )}
    </div>
  ) : (
    <div class="admin-card overflow-hidden">
      <div class="overflow-x-auto">
        <table class="admin-table" data-reorderable>
          <thead>
            <tr>
              <th class="w-8"></th>
              <th>Produk</th>
              <th>Kategori</th>
              <th>Harga</th>
              <th>Stok</th>
              <th>Featured</th>
              <th class="text-right">Aksi</th>
            </tr>
          </thead>
          <tbody data-reorder-body>
            {produkList.map((produk: any, idx: number) => (
              <tr
                draggable="true"
                data-id={produk.id}
                data-sort-order={produk.sort_order}
                class="cursor-grab active:cursor-grabbing"
              >
                <td class="text-samsung-ink/30 select-none">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <circle cx="9" cy="6" r="1.5"/><circle cx="15" cy="6" r="1.5"/>
                    <circle cx="9" cy="12" r="1.5"/><circle cx="15" cy="12" r="1.5"/>
                    <circle cx="9" cy="18" r="1.5"/><circle cx="15" cy="18" r="1.5"/>
                  </svg>
                </td>
                <td>
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-lg bg-samsung-mist overflow-hidden flex-shrink-0">
                      {produk.produk_foto?.[0]?.url ? (
                        <img src={produk.produk_foto[0].url} alt="" class="w-full h-full object-cover" />
                      ) : (
                        <div class="w-full h-full flex items-center justify-center">
                          <svg class="w-5 h-5 text-samsung-ink/20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                            <rect x="5" y="2" width="14" height="20" rx="2" ry="2" />
                          </svg>
                        </div>
                      )}
                    </div>
                    <div class="min-w-0">
                      <p class="font-medium text-samsung-ink truncate">{produk.nama}</p>
                      <p class="text-xs text-samsung-ink/50 truncate">
                        {(produk.spesifikasi as any)?.ram} &middot; {(produk.spesifikasi as any)?.storage}
                      </p>
                    </div>
                  </div>
                </td>
                <td>
                  <span class="badge-neutral capitalize">{produk.kategori}</span>
                </td>
                <td class="tabular-nums font-medium text-samsung-ink">
                  {formatRupiah(produk.harga)}
                </td>
                <td>
                  {produk.stok
                    ? <span class="badge-success">Tersedia</span>
                    : <span class="badge-danger">Habis</span>
                  }
                </td>
                <td>
                  {produk.is_featured
                    ? <span class="badge-warning">Featured</span>
                    : <span class="text-samsung-ink/30">&mdash;</span>
                  }
                </td>
                <td>
                  <div class="flex items-center justify-end gap-1">
                    <a
                      href={`/admin/produk/edit?id=${produk.id}`}
                      aria-label="Edit produk"
                      class="inline-flex items-center justify-center w-8 h-8 rounded-lg text-samsung-ink/60 hover:bg-samsung-blue/10 hover:text-samsung-blue transition-colors"
                    >
                      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" />
                        <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" />
                      </svg>
                    </a>
                    <button
                      data-id={produk.id}
                      data-name={produk.nama}
                      class="delete-btn inline-flex items-center justify-center w-8 h-8 rounded-lg text-samsung-ink/60 hover:bg-red-50 hover:text-red-600 transition-colors"
                      aria-label="Hapus produk"
                    >
                      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M3 6h18M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2M10 11v6M14 11v6" />
                      </svg>
                    </button>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="px-4 sm:px-5">
        <Pagination
          page={page}
          totalPages={totalPages}
          total={total}
          basePath="/admin/produk"
          extraParams={{ q }}
        />
      </div>
    </div>
  )}
</AdminLayout>

<script>
  import { toast } from '../../lib/toast';
  import '../../lib/confirm';

  // ── Delete ──
  document.querySelectorAll<HTMLButtonElement>('.delete-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const id = btn.dataset.id;
      const name = btn.dataset.name || 'produk ini';
      if (!id) return;

      try {
        const ok = await (window as any).confirmDialog({
          title: `Hapus "${name}"?`,
          message: 'Tindakan ini tidak bisa dibatalkan. Produk akan dihapus permanen dari database.',
          confirmText: 'Hapus',
          variant: 'danger',
          onConfirm: async () => {
            const res = await fetch(`/api/produk?id=${encodeURIComponent(id)}`, { method: 'DELETE' });
            const json = await res.json().catch(() => null);
            if (!res.ok) {
              const msg = (json && json.error) || `Gagal menghapus (HTTP ${res.status})`;
              toast.error(msg);
              throw new Error(msg);
            }
          },
        });
        if (ok) {
          toast.success(`"${name}" berhasil dihapus.`);
          setTimeout(() => window.location.reload(), 800);
        }
      } catch (err) {
        // Error already toasted
      }
    });
  });

  // ── Drag-to-reorder ──
  const tbody = document.querySelector<HTMLElement>('[data-reorder-body]');
  if (tbody) {
    let dragId: string | null = null;

    tbody.querySelectorAll<HTMLTableRowElement>('tr[draggable]').forEach((row) => {
      row.addEventListener('dragstart', (e) => {
        dragId = row.dataset.id || null;
        row.classList.add('opacity-40');
        e.dataTransfer?.setData('text/plain', dragId || '');
        e.dataTransfer!.effectAllowed = 'move';
      });
      row.addEventListener('dragend', () => {
        row.classList.remove('opacity-40');
        tbody.querySelectorAll('tr').forEach((r) => r.classList.remove('ring-2', 'ring-samsung-blue/30'));
        dragId = null;
      });
      row.addEventListener('dragover', (e) => {
        e.preventDefault();
        e.dataTransfer!.dropEffect = 'move';
        if (row.dataset.id !== dragId) {
          row.classList.add('ring-2', 'ring-samsung-blue/30');
        }
      });
      row.addEventListener('dragleave', () => {
        row.classList.remove('ring-2', 'ring-samsung-blue/30');
      });
      row.addEventListener('drop', async (e) => {
        e.preventDefault();
        row.classList.remove('ring-2', 'ring-samsung-blue/30');
        if (!dragId || row.dataset.id === dragId) return;

        const rows = Array.from(tbody.querySelectorAll<HTMLTableRowElement>('tr[draggable]'));
        const fromIdx = rows.findIndex((r) => r.dataset.id === dragId);
        const toIdx = rows.findIndex((r) => r.dataset.id === row.dataset.id);
        if (fromIdx === -1 || toIdx === -1) return;

        // Reorder DOM
        if (fromIdx < toIdx) row.after(rows[fromIdx]);
        else row.before(rows[fromIdx]);

        // Build new sort_order from current visual order, starting at 0 in 10-step
        const reordered = Array.from(tbody.querySelectorAll<HTMLTableRowElement>('tr[draggable]'));
        const items = reordered.map((r, i) => ({
          id: r.dataset.id!,
          sort_order: i * 10,
        }));

        try {
          const res = await fetch('/api/produk/reorder', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ items }),
          });
          const json = await res.json().catch(() => null);
          if (!res.ok) {
            toast.error((json && json.error) || 'Gagal simpan urutan');
            window.location.reload();
            return;
          }
          toast.success('Urutan diperbarui.');
        } catch (err) {
          toast.error((err as Error).message || 'Gagal simpan urutan');
          window.location.reload();
        }
      });
    });
  }
</script>
