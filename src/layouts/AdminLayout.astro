---
import Sidebar from '../components/admin/Sidebar.astro';
import '../styles/global.css';

interface Props {
  title: string;
  activeMenu?: string;
}

const { title, activeMenu = 'dashboard' } = Astro.props;
---

<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} - Admin Panel</title>
  </head>
  <body class="min-h-screen bg-samsung-mist text-samsung-ink font-admin antialiased">
    <Sidebar activeMenu={activeMenu} />

    <div class="lg:pl-60 min-h-screen flex flex-col">
      <!-- Top bar -->
      <header class="sticky top-0 z-20 bg-white/85 backdrop-blur-md border-b border-samsung-ink/5">
        <div class="h-14 px-4 sm:px-6 lg:px-8 flex items-center justify-between gap-4">
          <!-- Left: hamburger (mobile) + title -->
          <div class="flex items-center gap-3 min-w-0">
            <button
              data-sidebar-toggle
              type="button"
              aria-label="Buka menu"
              class="lg:hidden -ml-2 p-2 rounded-lg text-samsung-ink/70 hover:bg-samsung-ink/5 transition-colors"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 6h16M4 12h16M4 18h16" />
              </svg>
            </button>
            <h1 class="font-display font-bold text-base md:text-lg text-samsung-ink tracking-tight truncate">
              {title}
            </h1>
          </div>

          <!-- Right: user menu -->
          <div class="relative flex-shrink-0" data-user-menu>
            <button
              type="button"
              data-user-menu-trigger
              aria-haspopup="menu"
              aria-expanded="false"
              class="flex items-center gap-2 pl-1.5 pr-2 py-1.5 rounded-full
                     hover:bg-samsung-ink/5 active:scale-[0.98] transition-all duration-150"
            >
              <span
                data-user-avatar
                class="w-7 h-7 rounded-full bg-samsung-blue/10 text-samsung-blue
                       flex items-center justify-center text-xs font-display font-bold flex-shrink-0"
              >H</span>
              <span
                data-user-name
                class="hidden sm:inline text-sm font-medium text-samsung-ink max-w-[140px] truncate"
              ></span>
              <svg class="hidden sm:block w-3.5 h-3.5 text-samsung-ink/40 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M6 9l6 6 6-6" />
              </svg>
            </button>

            <!-- Dropdown -->
            <div
              data-user-menu-pop
              role="menu"
              class="user-menu-pop"
            >
              <div class="px-3 py-2 mb-1 border-b border-samsung-ink/5">
                <p class="text-xs text-samsung-ink/50 mb-0.5">Login sebagai</p>
                <p data-user-menu-email class="text-sm font-medium text-samsung-ink truncate"></p>
              </div>

              <a
                href="/"
                target="_blank"
                rel="noopener"
                role="menuitem"
                class="user-menu-item"
              >
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3" />
                </svg>
                Lihat Website
                <svg class="w-3 h-3 ml-auto text-samsung-ink/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M7 17L17 7M9 7h8v8" />
                </svg>
              </a>

              <a
                href="/admin/profil"
                role="menuitem"
                class="user-menu-item"
              >
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
                Edit Profil
              </a>

              <div class="my-1 mx-3 border-t border-samsung-ink/5"></div>

              <button
                type="button"
                role="menuitem"
                data-user-menu-logout
                class="user-menu-item-danger w-full"
              >
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9" />
                </svg>
                Logout
              </button>
            </div>
          </div>
        </div>
      </header>

      <!-- Page content -->
      <main class="flex-1 px-4 sm:px-6 lg:px-8 py-6 lg:py-8">
        <slot />
      </main>
    </div>

    <script>
      import { supabaseBrowser } from '../lib/supabase-browser';
      import { toast } from '../lib/toast';
      import '../lib/confirm';

      // Flash toast — show after page redirect
      try {
        const flash = sessionStorage.getItem('toast');
        if (flash) {
          sessionStorage.removeItem('toast');
          const { type, message } = JSON.parse(flash);
          if (type && message) {
            setTimeout(() => (toast as any)[type](message), 300);
          }
        }
      } catch (_) {}

      // User menu state
      const root = document.querySelector<HTMLElement>('[data-user-menu]');
      const trigger = document.querySelector<HTMLElement>('[data-user-menu-trigger]');
      const pop = document.querySelector<HTMLElement>('[data-user-menu-pop]');
      const emailEl = document.querySelector<HTMLElement>('[data-user-menu-email]');
      const nameEl = document.querySelector<HTMLElement>('[data-user-name]');
      const avatarEl = document.querySelector<HTMLElement>('[data-user-avatar]');

      function openMenu() {
        if (!pop || !trigger) return;
        pop.setAttribute('data-open', 'true');
        trigger.setAttribute('aria-expanded', 'true');
      }
      function closeMenu() {
        if (!pop || !trigger) return;
        pop.removeAttribute('data-open');
        trigger.setAttribute('aria-expanded', 'false');
      }
      function toggleMenu() {
        if (pop?.getAttribute('data-open') === 'true') closeMenu();
        else openMenu();
      }

      trigger?.addEventListener('click', (e) => {
        e.stopPropagation();
        toggleMenu();
      });
      document.addEventListener('click', (e) => {
        if (!root) return;
        if (!root.contains(e.target as Node)) closeMenu();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeMenu();
      });

      // Sidebar footer logout + topbar dropdown logout share handler
      async function handleLogout() {
        await supabaseBrowser.auth.signOut();
        document.cookie = 'sb-access-token=; path=/; max-age=0; SameSite=Lax';
        window.location.href = '/admin/login';
      }

      document
        .querySelector<HTMLElement>('[data-user-menu-logout]')
        ?.addEventListener('click', handleLogout);
      document
        .querySelector<HTMLElement>('[data-sidebar-logout]')
        ?.addEventListener('click', handleLogout);

      // Hydrate user info
      supabaseBrowser.auth.getSession().then(({ data: { session } }) => {
        if (session?.user?.email) {
          if (emailEl) emailEl.textContent = session.user.email;
          if (nameEl) nameEl.textContent = session.user.email.split('@')[0];
          if (avatarEl && session.user.email) {
            avatarEl.textContent = session.user.email.charAt(0).toUpperCase();
          }
        } else {
          window.location.href = '/admin/login';
        }
      });
    </script>
  </body>
</html>
